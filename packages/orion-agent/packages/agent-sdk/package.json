{
  "name": "@orion-ai/agent-sdk",
  "version": "0.0.5",
  "description": "Browser automation SDK for Orion - navigate, interact, extract data with natural language",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/orion-ai/Orion.git",
    "directory": "packages/agent-sdk"
  },
  "homepage": "https://github.com/orion-ai/Orion#readme",
  "bugs": {
    "url": "https://github.com/orion-ai/Orion/issues"
  },
  "keywords": [
    "orion",
    "browser-automation",
    "web-scraping",
    "ai-agent",
    "natural-language",
    "sdk"
  ],
  "scripts": {
    "build": "bunup && typedoc --json dist/api.json src/index.ts --excludePrivate",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api.json": "./dist/api.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./api.json": "./dist/api.json"
    }
  },
  "dependencies": {
    "eventsource-parser": "^3.0.6",
    "zod-to-json-schema": "^3.24.1"
  },
  "peerDependencies": {
    "zod": "^3.x"
  },
  "devDependencies": {
    "@orion/shared": "workspace:*",
    "bunup": "^0.16.17",
    "typedoc": "^0.28.15"
  }
}
