# Ports
ORION_CDP_PORT=9005
ORION_SERVER_PORT=9105
ORION_EXTENSION_PORT=9305
VITE_ORION_SERVER_PORT=9105

# Orion binary
ORION_BINARY=/Applications/Orion.app/Contents/MacOS/Orion

# Telemetry (browser bundle)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
VITE_PUBLIC_SENTRY_DSN=

# Orion API URL
VITE_PUBLIC_ORION_API=https://api.orion-browser.local

# Launch feature flags
VITE_PUBLIC_KIMI_LAUNCH=false

# GraphQL Schema Path (optional — falls back to schema/schema.graphql)
GRAPHQL_SCHEMA_PATH=

# Sentry build (source maps)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

NODE_ENV=development
